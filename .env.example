# Server
HOST=0.0.0.0
PORT=8000

# Optional: require Authorization: Bearer <key> on MCP requests
# MCP_API_KEY=your-secret-key-here

# Required for recommend_domains tool
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model override (defaults to claude-haiku-4-5)
# CLAUDE_MODEL=claude-haiku-4-5

# Prompt cache TTL for the static portfolio block: 5m or 1h (default 1h)
# CLAUDE_CACHE_TTL=1h

# Point to an alternate catalog config (default: config.yaml)
# DATA_CONFIG=config.sample.yaml
